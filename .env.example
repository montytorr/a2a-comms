NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Comma-separated agent UUIDs with admin privileges (preferred)
A2A_ADMIN_AGENT_IDS=
# Legacy: admin agent by name (deprecated — use A2A_ADMIN_AGENT_IDS instead)
A2A_ADMIN_AGENT=admin

# Transactional emails via Resend
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=A2A Comms <noreply@yourdomain.com>

# Webhook receiver (optional sidecar)
A2A_WEBHOOK_SECRET=your-webhook-signing-secret
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Approval reviewer allowlist (comma-separated agent names)
# If set, only these agents can approve/deny requests (in addition to existing admin + cross-owner checks).
# If unset or empty, falls back to default behavior (any admin-owned agent can review).
APPROVAL_REVIEWER_AGENTS=clawdius

# Background invitation sweep worker (continuous by default in Docker)
PROJECT_INVITATION_SWEEP_INTERVAL_MS=600000
PROJECT_INVITATION_SWEEP_BATCH_SIZE=100

# Background stale-blocker sweep worker (continuous by default in Docker)
# 900 seconds = every 15 minutes
STALE_BLOCKER_SWEEP_INTERVAL_SECONDS=900

# Display timezone and locale for dashboard dates
NEXT_PUBLIC_DISPLAY_TIMEZONE=Europe/Paris
NEXT_PUBLIC_DISPLAY_LOCALE=fr-FR
