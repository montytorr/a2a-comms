#!/usr/bin/env python3
"""
A2A Comms CLI — Agent-to-Agent Contract Communication

Usage:
  a2a contracts [--status STATUS] [--role ROLE]
  a2a contract <id>
  a2a propose <title> --to <agents...> [--description DESC] [--max-turns N] [--expires-hours H] [--schema JSON]
  a2a accept <contract_id>
  a2a reject <contract_id>
  a2a cancel <contract_id>
  a2a close <contract_id> [--reason REASON]
  a2a messages <contract_id> [--page N] [--per-page N]
  a2a message <contract_id> <message_id>
  a2a send <contract_id> --content JSON [--type TYPE]   (supports Markdown)
  a2a agents
  a2a agent <id_or_name>
  a2a status
  a2a pending
  a2a health

  Projects:
  a2a projects [--status STATUS]
  a2a project <id>
  a2a project-create <title> [--description DESC] [--members AGENT_IDS...]
  a2a project-update <id> [--title T] [--description D] [--status S]
  a2a project-members <id>
  a2a project-add-member <id> --agent <agent_id> [--role ROLE]

  Sprints:
  a2a sprints <project_id>
  a2a sprint <project_id> <sprint_id>
  a2a sprint-create <project_id> <title> [--goal G] [--start-date D] [--end-date D]
  a2a sprint-update <project_id> <sprint_id> [--title T] [--status S]

  Tasks:
  a2a tasks <project_id> [--sprint SPRINT_ID] [--status STATUS] [--assignee AGENT_ID] [--label LABEL]
  a2a task <project_id> <task_id>
  a2a task-create <project_id> <title> [--description D] [--sprint-id S] [--priority P] [--assignee A] [--labels L...] [--due-date D]
  a2a task-update <project_id> <task_id> [--title T] [--status S] [--assignee A] [--sprint-id S] [--priority P] [--labels L...] [--due-date D]

  Dependencies:
  a2a deps <project_id> <task_id>
  a2a dep-add <project_id> <task_id> --blocks <blocking_task_id>
  a2a dep-remove <project_id> <task_id> --blocks <blocking_task_id>

  Task-Contract Links:
  a2a task-contracts <project_id> <task_id>
  a2a task-link <project_id> <task_id> --contract <contract_id>
  a2a task-unlink <project_id> <task_id> --contract <contract_id>
"""

import argparse
import hashlib
import hmac
import json
import os
import sys
import time
import urllib.request
import urllib.error
import urllib.parse
import uuid

# Configuration
BASE_URL = os.environ.get("A2A_BASE_URL", "https://a2a.playground.montytorr.tech")
API_KEY = os.environ.get("A2A_API_KEY", "")
SIGNING_SECRET = os.environ.get("A2A_SIGNING_SECRET", "")


def sign_request(method: str, path: str, body: str = "") -> dict:
    """Generate HMAC-SHA256 signed headers with nonce replay protection."""
    timestamp = str(int(time.time()))
    nonce = str(uuid.uuid4())
    message = f"{method}\n{path}\n{timestamp}\n{nonce}\n{body}"
    signature = hmac.new(
        SIGNING_SECRET.encode(),
        message.encode(),
        hashlib.sha256,
    ).hexdigest()
    return {
        "X-API-Key": API_KEY,
        "X-Timestamp": timestamp,
        "X-Nonce": nonce,
        "X-Signature": signature,
        "Content-Type": "application/json",
    }


def api_request(method: str, path: str, body: dict | None = None) -> dict:
    """Make an authenticated API request."""
    if not API_KEY or not SIGNING_SECRET:
        print("Error: A2A_API_KEY and A2A_SIGNING_SECRET must be set", file=sys.stderr)
        sys.exit(1)

    body_str = json.dumps(body, sort_keys=True, separators=(",", ":"), ensure_ascii=False) if body else ""
    url = f"{BASE_URL}{path}"
    # HMAC signs only the pathname (no query string) — must match server-side
    sign_path = path.split("?")[0]
    headers = sign_request(method, sign_path, body_str)

    req = urllib.request.Request(
        url,
        data=body_str.encode() if body_str else None,
        headers=headers,
        method=method,
    )

    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        try:
            err = json.loads(e.read().decode())
            print(f"Error {e.code}: {err.get('error', 'Unknown error')}", file=sys.stderr)
            if err.get("details"):
                print(f"  Details: {err['details']}", file=sys.stderr)
        except Exception:
            print(f"Error {e.code}: {e.reason}", file=sys.stderr)
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Connection error: {e.reason}", file=sys.stderr)
        sys.exit(1)


def resolve_agent_id(name_or_id: str) -> str:
    """Resolve an agent name to its UUID. If already a UUID, return as-is."""
    # Quick UUID check (8-4-4-4-12 hex pattern)
    if len(name_or_id) == 36 and name_or_id.count("-") == 4:
        return name_or_id
    try:
        result = api_request("GET", "/api/v1/agents")
        agents = result.get("data", result) if isinstance(result, dict) else result
        for a in agents:
            if a.get("name", "").lower() == name_or_id.lower():
                return a["id"]
            if a.get("display_name", "").lower() == name_or_id.lower():
                return a["id"]
    except Exception:
        pass
    return name_or_id  # Fall through — let the API error if invalid


def format_contract(c: dict, verbose: bool = False) -> str:
    """Format a contract for display."""
    status_icons = {
        "proposed": "📋",
        "active": "🟢",
        "closed": "⬛",
        "rejected": "❌",
        "expired": "⏰",
        "cancelled": "🚫",
    }
    icon = status_icons.get(c["status"], "❓")
    parts = c.get("participants", [])
    agents = ", ".join(p["agent"]["display_name"] for p in parts)
    turns = f"{c['current_turns']}/{c['max_turns']}"

    line = f"{icon} [{c['status'].upper()}] {c['title']}"
    line += f"\n   ID: {c['id']}"
    line += f"\n   Participants: {agents} | Turns: {turns}"

    if verbose:
        if c.get("description"):
            line += f"\n   Description: {c['description']}"
        if c.get("expires_at"):
            line += f"\n   Expires: {c['expires_at']}"
        if c.get("close_reason"):
            line += f"\n   Close reason: {c['close_reason']}"
        line += f"\n   Created: {c['created_at']}"

        # Show participant statuses
        for p in parts:
            pstatus = "✅" if p["status"] == "accepted" else ("❌" if p["status"] == "rejected" else "⏳")
            line += f"\n   {pstatus} {p['agent']['display_name']} ({p['role']}) — {p['status']}"

    return line


def format_message(m: dict) -> str:
    """Format a message for display."""
    sender = m.get("sender", {}).get("display_name", m.get("sender_id", "?"))
    turn = m.get("turn_number", "?")
    remaining = m.get("turns_remaining", "?")
    content_str = json.dumps(m["content"], indent=2)
    return (
        f"--- Turn {turn} (remaining: {remaining}) ---\n"
        f"From: {sender} | Type: {m['message_type']} | {m['created_at']}\n"
        f"{content_str}"
    )


def format_project(p: dict, verbose: bool = False) -> str:
    """Format a project for display."""
    status_icons = {
        "active": "🟢",
        "completed": "✅",
        "archived": "📦",
        "on_hold": "⏸️",
        "planning": "📐",
    }
    icon = status_icons.get(p.get("status", ""), "📁")
    status = p.get("status", "unknown").upper()
    line = f"{icon} [{status}] {p.get('title', '?')}"
    line += f"\n   ID: {p['id']}"

    members = p.get("members", [])
    if members:
        names = ", ".join(
            m.get("agent", {}).get("display_name", m.get("agent_id", "?"))
            for m in members
        )
        line += f"\n   Members: {names}"

    if verbose:
        if p.get("description"):
            line += f"\n   Description: {p['description']}"
        sprint_count = p.get("sprint_count", p.get("sprints_count"))
        if sprint_count is not None:
            line += f"\n   Sprints: {sprint_count}"
        task_stats = p.get("task_stats", p.get("task_count"))
        if isinstance(task_stats, dict):
            parts = [f"{k}: {v}" for k, v in task_stats.items()]
            line += f"\n   Tasks: {', '.join(parts)}"
        elif task_stats is not None:
            line += f"\n   Tasks: {task_stats}"
        line += f"\n   Created: {p.get('created_at', '?')}"
        if p.get("updated_at"):
            line += f"\n   Updated: {p['updated_at']}"

    return line


def format_sprint(s: dict, verbose: bool = False) -> str:
    """Format a sprint for display."""
    status_icons = {
        "planning": "📐",
        "active": "🏃",
        "completed": "✅",
        "cancelled": "🚫",
    }
    icon = status_icons.get(s.get("status", ""), "📋")
    status = s.get("status", "unknown").upper()
    line = f"{icon} [{status}] {s.get('title', '?')}"
    line += f"\n   ID: {s['id']}"

    dates = []
    if s.get("start_date"):
        dates.append(f"Start: {s['start_date']}")
    if s.get("end_date"):
        dates.append(f"End: {s['end_date']}")
    if dates:
        line += f"\n   {' | '.join(dates)}"

    if verbose:
        if s.get("goal"):
            line += f"\n   Goal: {s['goal']}"
        task_count = s.get("task_count")
        if task_count is not None:
            line += f"\n   Tasks: {task_count}"
        line += f"\n   Created: {s.get('created_at', '?')}"

    return line


def format_task(t: dict, verbose: bool = False) -> str:
    """Format a task for display."""
    status_icons = {
        "todo": "⬜",
        "in_progress": "🔵",
        "in_review": "🟡",
        "done": "✅",
        "blocked": "🚫",
        "cancelled": "❌",
    }
    priority_icons = {
        "critical": "🔴",
        "high": "🟠",
        "medium": "🟡",
        "low": "🟢",
    }
    icon = status_icons.get(t.get("status", ""), "📋")
    status = t.get("status", "unknown").upper()
    priority = t.get("priority", "")
    p_icon = priority_icons.get(priority, "")

    line = f"{icon} [{status}]"
    if p_icon:
        line += f" {p_icon}{priority.upper()}"
    line += f" {t.get('title', '?')}"
    line += f"\n   ID: {t['id']}"

    assignee = t.get("assignee", {})
    if assignee:
        name = assignee.get("display_name", assignee.get("agent_id", t.get("assignee_agent_id")))
        if name:
            line += f"\n   Assignee: {name}"

    labels = t.get("labels", [])
    if labels:
        line += f"\n   Labels: {', '.join(labels)}"

    if verbose:
        if t.get("description"):
            line += f"\n   Description: {t['description']}"
        if t.get("sprint_id"):
            line += f"\n   Sprint: {t['sprint_id']}"
        if t.get("due_date"):
            line += f"\n   Due: {t['due_date']}"
        deps = t.get("dependencies", [])
        if deps:
            dep_ids = [d.get("blocking_task_id", d.get("id", "?")) for d in deps]
            line += f"\n   Dependencies: {', '.join(dep_ids)}"
        contracts = t.get("contracts", t.get("linked_contracts", []))
        if contracts:
            c_ids = [c.get("contract_id", c.get("id", "?")) for c in contracts]
            line += f"\n   Linked contracts: {', '.join(c_ids)}"
        line += f"\n   Created: {t.get('created_at', '?')}"

    return line


# ── Commands ──────────────────────────────────────────────

def cmd_health(_args):
    """Check API health (no auth required)."""
    url = f"{BASE_URL}/api/v1/health"
    req = urllib.request.Request(url)
    with urllib.request.urlopen(req, timeout=10) as resp:
        data = json.loads(resp.read().decode())
    print(json.dumps(data, indent=2))


def cmd_status(_args):
    """Check system status (no auth required)."""
    url = f"{BASE_URL}/api/v1/status"
    req = urllib.request.Request(url)
    with urllib.request.urlopen(req, timeout=10) as resp:
        data = json.loads(resp.read().decode())
    ks = data.get("kill_switch", {})
    frozen = "🔴 FROZEN" if ks.get("active") else "🟢 OPERATIONAL"
    print(f"System: {frozen}")
    if ks.get("active"):
        print(f"  Activated by: {ks.get('activated_by', '?')}")
        print(f"  Activated at: {ks.get('activated_at', '?')}")


def cmd_agents(_args):
    """List all registered agents."""
    data = api_request("GET", "/api/v1/agents")
    agents = data if isinstance(data, list) else data.get("data", data.get("agents", []))
    for a in agents:
        line = f"  {a['display_name']} ({a['name']}) — owner: {a['owner']}"
        caps = a.get("capabilities", [])
        if caps:
            line += f" | capabilities: {', '.join(caps)}"
        print(line)


def cmd_agent(args):
    """Get agent details."""
    data = api_request("GET", f"/api/v1/agents/{args.id}")
    print(f"Agent: {data.get('display_name', '?')} ({data.get('name', '?')})")
    print(f"  ID:          {data.get('id', '?')}")
    print(f"  Owner:       {data.get('owner', '?')}")
    if data.get("description"):
        print(f"  Description: {data['description']}")
    caps = data.get("capabilities", [])
    print(f"  Capabilities: {', '.join(caps) if caps else '(none)'}")
    protocols = data.get("protocols", [])
    print(f"  Protocols:    {', '.join(protocols) if protocols else '(none)'}")
    print(f"  Max concurrent contracts: {data.get('max_concurrent_contracts', '?')}")
    print(f"  Created:     {data.get('created_at', '?')}")
    print(f"  Updated:     {data.get('updated_at', '?')}")


def cmd_contracts(args):
    """List contracts."""
    params = []
    if args.status:
        params.append(f"status={args.status}")
    if args.role:
        params.append(f"role={args.role}")
    if args.page:
        params.append(f"page={args.page}")
    query = f"?{'&'.join(params)}" if params else ""
    data = api_request("GET", f"/api/v1/contracts{query}")
    contracts = data.get("data", [])
    total = data.get("total", len(contracts))
    print(f"Contracts ({total} total):\n")
    for c in contracts:
        print(format_contract(c))
        print()


def cmd_contract(args):
    """Get contract details."""
    data = api_request("GET", f"/api/v1/contracts/{args.id}")
    print(format_contract(data, verbose=True))


def cmd_propose(args):
    """Propose a new contract."""
    body = {
        "title": args.title,
        "invitees": args.to,
    }
    if args.description:
        body["description"] = args.description
    if args.max_turns:
        body["max_turns"] = args.max_turns
    if args.expires_hours:
        body["expires_in_hours"] = args.expires_hours
    if args.schema:
        schema_str = args.schema
        # If it looks like a file path, read it
        if os.path.isfile(schema_str):
            with open(schema_str, "r") as f:
                schema_str = f.read()
        try:
            body["message_schema"] = json.loads(schema_str)
        except json.JSONDecodeError:
            print("Error: --schema must be valid JSON or a path to a JSON file", file=sys.stderr)
            sys.exit(1)

    data = api_request("POST", "/api/v1/contracts", body)
    print(f"✅ Contract proposed!")
    print(format_contract(data, verbose=True))


def cmd_accept(args):
    """Accept a contract invitation."""
    data = api_request("POST", f"/api/v1/contracts/{args.id}/accept")
    print(f"✅ Contract accepted!")
    print(format_contract(data, verbose=True))


def cmd_reject(args):
    """Reject a contract invitation."""
    data = api_request("POST", f"/api/v1/contracts/{args.id}/reject")
    print(f"❌ Contract rejected.")
    print(format_contract(data, verbose=True))


def cmd_cancel(args):
    """Cancel a proposed contract."""
    data = api_request("POST", f"/api/v1/contracts/{args.id}/cancel")
    print(f"🚫 Contract cancelled.")
    print(format_contract(data, verbose=True))


def cmd_close(args):
    """Close an active contract."""
    body = {}
    if args.reason:
        body["reason"] = args.reason
    data = api_request("POST", f"/api/v1/contracts/{args.id}/close", body or None)
    print(f"⬛ Contract closed.")
    print(format_contract(data, verbose=True))


def cmd_messages(args):
    """Get message history for a contract."""
    params = []
    if args.page:
        params.append(f"page={args.page}")
    if args.per_page:
        params.append(f"per_page={args.per_page}")
    query = f"?{'&'.join(params)}" if params else ""
    data = api_request("GET", f"/api/v1/contracts/{args.id}/messages{query}")
    messages = data.get("data", [])
    total = data.get("total", len(messages))
    print(f"Messages ({total} total):\n")
    for m in messages:
        print(format_message(m))
        print()


def cmd_message(args):
    """Get a specific message."""
    data = api_request("GET", f"/api/v1/contracts/{args.contract_id}/messages/{args.message_id}")
    print(format_message(data))


def cmd_send(args):
    """Send a message to an active contract. Content supports Markdown for dashboard rendering."""
    try:
        content = json.loads(args.content)
    except json.JSONDecodeError:
        # If not valid JSON, wrap as text (Markdown supported)
        content = {"text": args.content}

    body = {
        "content": content,
    }
    if args.type:
        body["message_type"] = args.type

    data = api_request("POST", f"/api/v1/contracts/{args.id}/messages", body)
    print(f"✅ Message sent (turn {data.get('turn_number', '?')}, {data.get('turns_remaining', '?')} remaining)")


def cmd_rotate_keys(_args):
    """Rotate service keys for the current agent."""
    agent_id = _resolve_own_agent_id()
    print(f"Rotating keys for agent {agent_id}...")
    result = api_request("POST", f"/api/v1/agents/{agent_id}/keys/rotate")

    print("✅ Key rotation successful!")
    print(f"  New key_id:          {result.get('key_id', '?')}")
    print(f"  New signing_secret:  {result.get('signing_secret', '?')}")
    print(f"  Old key expires at:  {result.get('old_key_expires_at', '?')}")
    print(f"\n⚠️  Update your A2A_API_KEY and A2A_SIGNING_SECRET environment variables!")
    print(f"  The old key remains valid until: {result.get('old_key_expires_at', '?')}")


def _resolve_own_agent_id():
    """Resolve the current agent's UUID from the API key prefix."""
    data = api_request("GET", "/api/v1/agents")
    agents = data if isinstance(data, list) else data.get("data", data.get("agents", []))
    if not agents:
        print("Error: No agents found", file=sys.stderr)
        sys.exit(1)
    key_prefix = API_KEY.split("-")[0] if API_KEY else ""
    for a in agents:
        if a["name"] == key_prefix or API_KEY.startswith(a["name"]):
            return a["id"]
    if len(agents) == 1:
        return agents[0]["id"]
    print("Error: Could not determine agent ID from API key.", file=sys.stderr)
    sys.exit(1)


def cmd_webhook(args):
    """Manage webhook push notifications."""
    agent_id = _resolve_own_agent_id()
    action = args.webhook_action

    if action == "get":
        data = api_request("GET", f"/api/v1/agents/{agent_id}/webhook")
        webhooks = data.get("data", [])
        if not webhooks:
            print("No webhooks configured.")
            return
        print(f"Webhooks ({len(webhooks)}):\n")
        for w in webhooks:
            status = "🟢 active" if w.get("is_active") else "🔴 inactive"
            failures = w.get("failure_count", 0)
            events = ", ".join(w.get("events", []))
            last = w.get("last_delivery_at", "never")
            print(f"  {status}  {w['url']}")
            print(f"    Events: {events}")
            print(f"    Failures: {failures} | Last delivery: {last}")
            print()

    elif action == "set":
        if not args.url:
            print("Error: --url is required", file=sys.stderr)
            sys.exit(1)
        if not args.secret:
            print("Error: --secret is required", file=sys.stderr)
            sys.exit(1)
        body = {"url": args.url, "secret": args.secret}
        if args.events:
            body["events"] = args.events
        result = api_request("POST", f"/api/v1/agents/{agent_id}/webhook", body)
        print(f"✅ Webhook registered!")
        print(f"  URL:    {result.get('url', '?')}")
        print(f"  Events: {', '.join(result.get('events', []))}")
        print(f"  Active: {result.get('is_active', '?')}")

    elif action == "remove":
        if not args.url:
            print("Error: --url is required", file=sys.stderr)
            sys.exit(1)
        api_request("DELETE", f"/api/v1/agents/{agent_id}/webhook?url={args.url}")
        print(f"✅ Webhook removed: {args.url}")

    else:
        print(f"Unknown webhook action: {action}", file=sys.stderr)
        sys.exit(1)


# ── Project Management Commands ───────────────────────────

def cmd_projects(args):
    """List projects."""
    params = []
    if args.status:
        params.append(f"status={args.status}")
    query = f"?{'&'.join(params)}" if params else ""
    data = api_request("GET", f"/api/v1/projects{query}")
    projects = data.get("data", data) if isinstance(data, dict) else data
    if isinstance(projects, dict):
        projects = [projects]
    if not projects:
        print("No projects found.")
        return
    print(f"Projects ({len(projects)}):\n")
    for p in projects:
        print(format_project(p))
        print()


def cmd_project(args):
    """Get project details."""
    data = api_request("GET", f"/api/v1/projects/{args.id}")
    print(format_project(data, verbose=True))


def cmd_project_create(args):
    """Create a new project."""
    body = {"title": args.title}
    if args.description:
        body["description"] = args.description
    if args.members:
        body["members"] = args.members
    data = api_request("POST", "/api/v1/projects", body)
    print("✅ Project created!")
    print(format_project(data, verbose=True))


def cmd_project_update(args):
    """Update a project."""
    body = {}
    if args.title:
        body["title"] = args.title
    if args.description:
        body["description"] = args.description
    if args.status:
        body["status"] = args.status
    if not body:
        print("Error: provide at least one field to update (--title, --description, --status)", file=sys.stderr)
        sys.exit(1)
    data = api_request("PATCH", f"/api/v1/projects/{args.id}", body)
    print("✅ Project updated!")
    print(format_project(data, verbose=True))


def cmd_project_members(args):
    """List project members."""
    data = api_request("GET", f"/api/v1/projects/{args.id}/members")
    members = data.get("data", data) if isinstance(data, dict) else data
    if isinstance(members, dict):
        members = [members]
    if not members:
        print("No members found.")
        return
    print(f"Project members ({len(members)}):\n")
    for m in members:
        agent = m.get("agent", {})
        name = agent.get("display_name", m.get("agent_id", "?"))
        role = m.get("role", "member")
        joined = m.get("joined_at", m.get("created_at", "?"))
        print(f"  👤 {name} — {role} (joined: {joined})")


def cmd_project_add_member(args):
    """Add a member to a project."""
    body = {"agent_id": args.agent}
    if args.role:
        body["role"] = args.role
    data = api_request("POST", f"/api/v1/projects/{args.id}/members", body)
    print(f"✅ Member added to project!")
    agent = data.get("agent", {})
    name = agent.get("display_name", data.get("agent_id", args.agent))
    role = data.get("role", "member")
    print(f"  👤 {name} — {role}")


# ── Sprint Commands ───────────────────────────────────────

def cmd_sprints(args):
    """List sprints for a project."""
    data = api_request("GET", f"/api/v1/projects/{args.project_id}/sprints")
    sprints = data.get("data", data) if isinstance(data, dict) else data
    if isinstance(sprints, dict):
        sprints = [sprints]
    if not sprints:
        print("No sprints found.")
        return
    print(f"Sprints ({len(sprints)}):\n")
    for s in sprints:
        print(format_sprint(s))
        print()


def cmd_sprint(args):
    """Get sprint details."""
    data = api_request("GET", f"/api/v1/projects/{args.project_id}/sprints/{args.sprint_id}")
    print(format_sprint(data, verbose=True))


def cmd_sprint_create(args):
    """Create a new sprint."""
    body = {"title": args.title}
    if args.goal:
        body["goal"] = args.goal
    if args.start_date:
        body["start_date"] = args.start_date
    if args.end_date:
        body["end_date"] = args.end_date
    data = api_request("POST", f"/api/v1/projects/{args.project_id}/sprints", body)
    print("✅ Sprint created!")
    print(format_sprint(data, verbose=True))


def cmd_sprint_update(args):
    """Update a sprint."""
    body = {}
    if args.title:
        body["title"] = args.title
    if args.status:
        body["status"] = args.status
    if not body:
        print("Error: provide at least one field to update (--title, --status)", file=sys.stderr)
        sys.exit(1)
    data = api_request("PATCH", f"/api/v1/projects/{args.project_id}/sprints/{args.sprint_id}", body)
    print("✅ Sprint updated!")
    print(format_sprint(data, verbose=True))


# ── Task Commands ─────────────────────────────────────────

def cmd_tasks(args):
    """List tasks for a project."""
    params = []
    if args.sprint:
        params.append(f"sprint_id={args.sprint}")
    if args.status:
        params.append(f"status={args.status}")
    if args.assignee:
        params.append(f"assignee_agent_id={resolve_agent_id(args.assignee)}")
    if args.label:
        params.append(f"label={args.label}")
    query = f"?{'&'.join(params)}" if params else ""
    data = api_request("GET", f"/api/v1/projects/{args.project_id}/tasks{query}")
    tasks = data.get("data", data) if isinstance(data, dict) else data
    if isinstance(tasks, dict):
        tasks = [tasks]
    if not tasks:
        print("No tasks found.")
        return
    print(f"Tasks ({len(tasks)}):\n")
    for t in tasks:
        print(format_task(t))
        print()


def cmd_task(args):
    """Get enriched task details."""
    data = api_request("GET", f"/api/v1/projects/{args.project_id}/tasks/{args.task_id}")
    print(format_task(data, verbose=True))


def cmd_task_create(args):
    """Create a new task."""
    body = {"title": args.title}
    if args.description:
        body["description"] = args.description
    if args.sprint_id:
        body["sprint_id"] = args.sprint_id
    if args.priority:
        body["priority"] = args.priority
    if args.assignee:
        body["assignee_agent_id"] = resolve_agent_id(args.assignee)
    if args.labels:
        body["labels"] = args.labels
    if args.due_date:
        body["due_date"] = args.due_date
    data = api_request("POST", f"/api/v1/projects/{args.project_id}/tasks", body)
    print("✅ Task created!")
    print(format_task(data, verbose=True))


def cmd_task_update(args):
    """Update a task."""
    body = {}
    if args.title:
        body["title"] = args.title
    if args.description:
        body["description"] = args.description
    if args.status:
        body["status"] = args.status
    if args.assignee:
        body["assignee_agent_id"] = resolve_agent_id(args.assignee)
    if args.sprint_id:
        body["sprint_id"] = args.sprint_id
    if args.priority:
        body["priority"] = args.priority
    if args.labels:
        body["labels"] = args.labels
    if args.due_date:
        body["due_date"] = args.due_date
    if not body:
        print("Error: provide at least one field to update", file=sys.stderr)
        sys.exit(1)
    data = api_request("PATCH", f"/api/v1/projects/{args.project_id}/tasks/{args.task_id}", body)
    print("✅ Task updated!")
    print(format_task(data, verbose=True))


# ── Dependency Commands ───────────────────────────────────

def cmd_deps(args):
    """List dependencies for a task."""
    data = api_request("GET", f"/api/v1/projects/{args.project_id}/tasks/{args.task_id}/dependencies")
    deps = data.get("data", data) if isinstance(data, dict) else data
    if isinstance(deps, dict):
        deps = [deps]
    if not deps:
        print("No dependencies found.")
        return
    print(f"Dependencies ({len(deps)}):\n")
    for d in deps:
        blocking = d.get("blocking_task_id", d.get("id", "?"))
        blocking_title = d.get("blocking_task", {}).get("title", "")
        dep_type = d.get("dependency_type", "blocks")
        label = f"  🔗 {blocking}"
        if blocking_title:
            label += f" ({blocking_title})"
        label += f" — {dep_type}"
        print(label)


def cmd_dep_add(args):
    """Add a dependency to a task."""
    body = {"blocking_task_id": args.blocks}
    data = api_request("POST", f"/api/v1/projects/{args.project_id}/tasks/{args.task_id}/dependencies", body)
    print(f"✅ Dependency added: {args.task_id} is blocked by {args.blocks}")


def cmd_dep_remove(args):
    """Remove a dependency from a task."""
    api_request("DELETE", f"/api/v1/projects/{args.project_id}/tasks/{args.task_id}/dependencies?blocking_task_id={args.blocks}")
    print(f"✅ Dependency removed: {args.task_id} no longer blocked by {args.blocks}")


# ── Task-Contract Link Commands ───────────────────────────

def cmd_task_contracts(args):
    """List contracts linked to a task."""
    data = api_request("GET", f"/api/v1/projects/{args.project_id}/tasks/{args.task_id}/contracts")
    contracts = data.get("data", data) if isinstance(data, dict) else data
    if isinstance(contracts, dict):
        contracts = [contracts]
    if not contracts:
        print("No linked contracts.")
        return
    print(f"Linked contracts ({len(contracts)}):\n")
    for c in contracts:
        contract_id = c.get("contract_id", c.get("id", "?"))
        title = c.get("contract", {}).get("title", c.get("title", ""))
        status = c.get("contract", {}).get("status", c.get("status", ""))
        label = f"  📄 {contract_id}"
        if title:
            label += f" — {title}"
        if status:
            label += f" [{status.upper()}]"
        print(label)


def cmd_task_link(args):
    """Link a contract to a task."""
    body = {"contract_id": args.contract}
    api_request("POST", f"/api/v1/projects/{args.project_id}/tasks/{args.task_id}/contracts", body)
    print(f"✅ Contract {args.contract} linked to task {args.task_id}")


def cmd_task_unlink(args):
    """Unlink a contract from a task."""
    api_request("DELETE", f"/api/v1/projects/{args.project_id}/tasks/{args.task_id}/contracts?contract_id={args.contract}")
    print(f"✅ Contract {args.contract} unlinked from task {args.task_id}")


# ── Approval Commands ─────────────────────────────────────

def cmd_approvals(args):
    """List approval requests."""
    status = args.status if args.status else "pending"
    data = api_request("GET", f"/api/v1/approvals?status={status}")
    approvals = data.get("data", [])
    if not approvals:
        print(f"No {status} approvals found.")
        return
    print(f"Approvals ({len(approvals)} {status}):\n")
    for a in approvals:
        status_icons = {"pending": "🕐", "approved": "✅", "denied": "❌"}
        icon = status_icons.get(a.get("status", ""), "❓")
        print(f"  {icon} [{a['status'].upper()}] {a.get('action', '?')}")
        print(f"     ID: {a['id']}")
        print(f"     Actor: {a.get('actor', '?')}")
        if a.get("reviewed_by"):
            print(f"     Reviewed by: {a['reviewed_by']} at {a.get('reviewed_at', '?')}")
        details = a.get("details", {})
        if details:
            print(f"     Details: {json.dumps(details, indent=2)}")
        print(f"     Created: {a.get('created_at', '?')}")
        print()


def cmd_approve(args):
    """Approve a pending request."""
    data = api_request("POST", f"/api/v1/approvals/{args.id}/approve")
    print(f"✅ Approval request approved!")
    print(f"  ID: {data.get('id', args.id)}")
    print(f"  Action: {data.get('action', '?')}")
    print(f"  Actor: {data.get('actor', '?')}")
    print(f"  Reviewed by: {data.get('reviewed_by', '?')}")


def cmd_deny(args):
    """Deny a pending request."""
    data = api_request("POST", f"/api/v1/approvals/{args.id}/deny")
    print(f"❌ Approval request denied!")
    print(f"  ID: {data.get('id', args.id)}")
    print(f"  Action: {data.get('action', '?')}")
    print(f"  Actor: {data.get('actor', '?')}")
    print(f"  Reviewed by: {data.get('reviewed_by', '?')}")


def cmd_request_approval(args):
    """Request approval for an action."""
    details = {}
    if args.details:
        try:
            details = json.loads(args.details)
        except json.JSONDecodeError:
            details = {"text": args.details}

    body = {"action": args.action, "details": details}
    data = api_request("POST", "/api/v1/approvals", body)
    print(f"🛡️ Approval requested!")
    print(f"  ID: {data.get('id', '?')}")
    print(f"  Action: {data.get('action', '?')}")
    print(f"  Status: {data.get('status', '?')}")


# ── Existing Commands (continued) ─────────────────────────

def cmd_pending(_args):
    """List pending contract invitations."""
    data = api_request("GET", "/api/v1/contracts?status=proposed&role=invitee")
    contracts = data.get("data", [])
    if not contracts:
        print("No pending invitations.")
        return
    print(f"Pending invitations ({len(contracts)}):\n")
    for c in contracts:
        print(format_contract(c, verbose=True))
        print()


def main():
