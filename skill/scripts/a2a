        # Sprints
        "sprints": cmd_sprints,
        "sprint": cmd_sprint,
        "sprint-create": cmd_sprint_create,
        "sprint-update": cmd_sprint_update,
        # Tasks
        "tasks": cmd_tasks,
        "task": cmd_task,
        "task-create": cmd_task_create,
        "task-update": cmd_task_update,
        # Dependencies
        "deps": cmd_deps,
        "dep-add": cmd_dep_add,
        "dep-remove": cmd_dep_remove,
        # Task-Contract links
        "task-contracts": cmd_task_contracts,
        "task-link": cmd_task_link,
        "task-unlink": cmd_task_unlink,
        # Approvals
        "approvals": cmd_approvals,
        "approve": cmd_approve,
        "deny": cmd_deny,
        "request-approval": cmd_request_approval,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
