    p.add_argument("--contract", required=True, help="Contract ID to unlink")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(1)

    commands = {
        "health": cmd_health,
        "status": cmd_status,
        "agents": cmd_agents,
        "agent": cmd_agent,
        "contracts": cmd_contracts,
        "contract": cmd_contract,
        "propose": cmd_propose,
        "accept": cmd_accept,
        "reject": cmd_reject,
        "cancel": cmd_cancel,
        "close": cmd_close,
        "messages": cmd_messages,
        "message": cmd_message,
        "send": cmd_send,
