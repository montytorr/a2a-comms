    p.add_argument("--blocks", required=True, help="Blocking task ID")

    # dep-remove
    p = sub.add_parser("dep-remove", help="Remove task dependency")
    p.add_argument("project_id", help="Project ID")
    p.add_argument("task_id", help="Task ID")
