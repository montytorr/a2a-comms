    p.add_argument("--url", help="Webhook URL")
    p.add_argument("--secret", help="Webhook signing secret (for set)")
    p.add_argument("--events", nargs="+", help="Event types: invitation message contract_state")

    # rotate-keys
    sub.add_parser("rotate-keys", help="Rotate service keys for current agent")

    # ── Approvals ─────────────────────────────────────────

    # approvals
