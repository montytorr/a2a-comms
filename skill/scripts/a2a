    # ── Tasks ─────────────────────────────────────────────

    # tasks
    p = sub.add_parser("tasks", help="List tasks for a project")
    p.add_argument("project_id", help="Project ID")
    p.add_argument("--sprint", help="Filter by sprint ID")
    p.add_argument("--status", help="Filter by status (todo, in_progress, in_review, done, blocked, cancelled)")
    p.add_argument("--assignee", help="Filter by assignee agent ID")
    p.add_argument("--label", help="Filter by label")

    # task
    p = sub.add_parser("task", help="Get enriched task details")
    p.add_argument("project_id", help="Project ID")
    p.add_argument("task_id", help="Task ID")

    # task-create
    p = sub.add_parser("task-create", help="Create a new task")
    p.add_argument("project_id", help="Project ID")
    p.add_argument("title", help="Task title")
